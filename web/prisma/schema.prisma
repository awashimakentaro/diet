/**
 * web/prisma/schema.prisma
 *
 * 【責務】
 * Web 版で利用する Supabase Postgres 向け Prisma スキーマを定義する。
 *
 * 【使用箇所】
 * - `npm run prisma:generate`
 *
 * 【やらないこと】
 * - Next.js 画面実装
 * - API ハンドラ実装
 *
 * 【他ファイルとの関係】
 * - Prisma Client の生成元として扱われる。
 * - Supabase Auth の `auth.users` への外部キーは `userId` scalar として保持する。
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Food {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  amount    String
  calories  Decimal  @db.Decimal
  protein   Decimal  @db.Decimal
  fat       Decimal  @db.Decimal
  carbs     Decimal  @db.Decimal
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  items     Json     @default(dbgenerated("'[]'::jsonb")) @db.JsonB

  @@map("foods")
}

model Goal {
  userId    String   @id @map("user_id") @db.Uuid
  calories  Decimal  @db.Decimal
  protein   Decimal  @db.Decimal
  fat       Decimal  @db.Decimal
  carbs     Decimal  @db.Decimal
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("goals")
}

model Meal {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  originalText String @map("original_text")
  foods      Json     @db.JsonB
  total      Json     @db.JsonB
  timestamp  DateTime @default(now()) @db.Timestamptz(6)
  insertedAt DateTime @default(now()) @map("inserted_at") @db.Timestamptz(6)
  menuName   String   @map("menu_name")

  @@map("meals")
}

model NotificationPreference {
  userId            String   @id @map("user_id") @db.Uuid
  notifyAtMidnight  Boolean  @default(true) @map("notify_at_midnight")
  pushToken         String?  @map("push_token")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("notification_preferences")
}
